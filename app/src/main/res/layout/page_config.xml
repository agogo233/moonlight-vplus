<?xml version="1.0" encoding="utf-8"?>
<com.limelight.binding.input.advance_setting.superpage.SuperPageLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="320dp"
    android:layout_height="match_parent"
    android:tag="320">

    <ScrollView
        android:id="@+id/crown_config_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginEnd="5dp"
        android:background="@drawable/crown_config_panel_bg"
        android:clipToPadding="false"
        android:fillViewport="false"
        android:paddingHorizontal="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/crown_page_title" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/page_config_section_profile"
                android:textColor="@color/crown_accent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/crown_config_section_bg"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    android:text="@string/layout_page_config_text_9eba2"
                    android:textColor="@color/crown_text_secondary"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/config_select_spinner"
                    android:layout_width="match_parent"
                    android:layout_height="34dp"
                    android:background="@drawable/crown_config_input_bg"
                    android:max="10"
                    android:min="1"
                    app:progress="10" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/page_config_section_touch"
                android:textColor="@color/crown_accent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/crown_config_section_bg"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/layout_page_config_text_83a23"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/mouse_enable_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/layout_page_config_text_f4b7c"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/trackpad_enable_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/enhanced_touch_layout"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/layout_page_config_text_8ea81"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/enhanced_touch_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false"
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/mouse_sense_number_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="4dp"
                    app:max="500"
                    app:min="1"
                    app:progress="100"
                    app:text="@string/apptext_pg_config_835d4" />

                <com.limelight.binding.input.advance_setting.superpage.NumberSeekbar
                    android:id="@+id/mouse_wheel_speed_number_seekbar"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:layout_marginTop="4dp"
                    app:max="100"
                    app:min="1"
                    app:progress="20"
                    app:text="@string/apptext_pg_config_3f729" />
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/page_config_section_feedback"
                android:textColor="@color/crown_accent"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/crown_config_section_bg"
                android:orientation="vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/layout_page_config_text_cd2c1"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/game_vibrator_enable_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/layout_page_config_text_f4651"
                        android:textColor="@color/crown_text_primary"
                        android:textSize="13sp" />

                    <Switch
                        android:id="@+id/button_vibrator_enable_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:thumbTint="@color/crown_switch_thumb"
                        android:trackTint="@color/crown_switch_track" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/crown_config_action_bar"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="top|end"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="10dp"
        android:gravity="end"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/add_config_button"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="4dp"
            android:background="@drawable/crown_action_icon_button_bg"
            android:contentDescription="@string/layout_page_config_text_66ab5"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/phc_action_plus"
            android:tint="@color/crown_text_primary" />

        <ImageButton
            android:id="@+id/rename_config_button"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/crown_action_icon_button_bg"
            android:contentDescription="@string/layout_config_item_text_c8ce4"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/phc_action_edit"
            android:tint="@color/crown_text_primary" />

        <ImageButton
            android:id="@+id/delete_config_button"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="2dp"
            android:background="@drawable/crown_action_icon_button_bg"
            android:contentDescription="@string/layout_config_item_text_2f4aa"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/phc_action_trash"
            android:tint="@color/crown_text_primary" />

        <ImageButton
            android:id="@+id/exit_crown_config_button"
            android:layout_width="32dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:background="@drawable/crown_action_icon_button_bg"
            android:contentDescription="@string/layout_page_config_text_df603"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/phc_action_check"
            android:tint="@color/crown_text_primary" />
    </LinearLayout>
</com.limelight.binding.input.advance_setting.superpage.SuperPageLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginBottom="5dp"
        android:gravity="center_vertical">
        <TextView
            android:id="@+id/number_seekbar_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@color/crown_text_secondary"
            android:text="@string/layout_number_seekbar_text_e12e7"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_height="30dp">
            <View
                android:id="@+id/number_seekbar_minus"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:layout_marginEnd="5dp"
                android:scaleX="0.5"
                android:scaleY="0.67"
                android:layout_gravity="center_vertical"
                android:background="@drawable/minus"/>
            <TextView
                android:id="@+id/number_seekbar_number"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/crown_text_primary"
                android:text="100"/>
            <View
                android:id="@+id/number_seekbar_add"
                android:layout_width="40dp"
                android:layout_height="30dp"
                android:layout_marginStart="5dp"
                android:scaleX="0.5"
                android:scaleY="0.67"
                android:layout_gravity="center_vertical"
                android:background="@drawable/add"/>
        </LinearLayout>


    </LinearLayout>
    <SeekBar
        android:id="@+id/number_seekbar_seekbar"
        android:layout_width="match_parent"
        android:layout_height="25dp"
        android:max="500"
        android:min="1"
        android:progressTint="@color/crown_accent"
        android:thumbTint="@color/crown_accent"
        android:progressBackgroundTint="@color/crown_input_border"
        android:progress="100"/>

</LinearLayout>

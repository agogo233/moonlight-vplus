<?xml version="1.0" encoding="utf-8"?>
<com.limelight.binding.input.advance_setting.superpage.SuperPageLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="match_parent"
    android:tag="320">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginEnd="5dp"
        android:background="@drawable/crown_config_panel_bg"
        android:padding="10dp">

        <LinearLayout
            android:id="@+id/page_super_menu_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <include layout="@layout/crown_page_title" />

            <LinearLayout
                android:id="@+id/page_super_menu_config_page"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_super_menu_text_899a4"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_super_menu_edit_mode"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_item_page_super_menu_text_ce0e8"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_super_menu_toggle_normal_mode"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginBottom="6dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/crown_switch_to_normal"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/page_super_menu_disconnect"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:background="@drawable/crown_config_action_button_bg"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="@string/layout_page_super_menu_text_e2f14"
                    android:textColor="@color/crown_text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_arrow_right" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</com.limelight.binding.input.advance_setting.superpage.SuperPageLayout>

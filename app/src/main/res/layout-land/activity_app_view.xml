<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/advance_setting_background"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".AppView">

    <!-- 背景图容器 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 高斯模糊背景 -->
        <ImageView
            android:id="@+id/appBackgroundImageBlur"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <!-- 中间完整图片 -->
        <ImageView
            android:id="@+id/appBackgroundImageClear"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter" />

    </FrameLayout>

    <!-- App 图标网格容器 -->
    <FrameLayout
        android:id="@+id/appFragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true" />

    <!-- 选中框动画 -->
    <View
        android:id="@+id/selectionIndicator"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/selection_indicator"
        android:visibility="invisible"
        android:elevation="8dp"
        android:clipChildren="false"
        android:clipToPadding="false" />

    <View
        android:id="@+id/topPanelScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#00000000"
        android:clickable="true"
        android:focusable="true"
        android:importantForAccessibility="no"
        android:visibility="gone" />

    <!-- 顶部下拉手柄标签 -->
    <TextView
        android:id="@+id/topPanelToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="@dimen/activity_safearea_top"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="\u2699 \u25BE"
        android:textColor="#E6FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-light"
        android:background="@drawable/dropdown_handle_background"
        android:elevation="4dp"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="false" />

    <!-- 顶部下拉面板 -->
    <ScrollView
        android:id="@+id/topDropdownPanel"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_below="@id/topPanelToggle"
        android:layout_centerHorizontal="true"
        android:background="@drawable/dropdown_panel_background"
        android:padding="@dimen/appview_panel_padding"
        android:elevation="@dimen/appview_panel_elevation"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:fillViewport="false"
        android:scrollbars="vertical"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:overScrollMode="never"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/topDropdownPanelContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:descendantFocusability="afterDescendants">

        <!-- 设置入口 -->
        <TextView
            android:id="@+id/settingsEntry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:text="@string/title_settings"
            android:textColor="@color/appview_text_primary"
            android:textSize="14sp"
            android:fontFamily="sans-serif-light"
            android:drawableStart="@drawable/phc_settings"
            android:drawablePadding="12dp"
            android:drawableTint="@color/appview_text_primary"
            android:gravity="center_vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:paddingStart="12dp"
            android:paddingEnd="16dp"
            android:background="@drawable/appview_panel_item_background"
            android:clickable="true"
            android:focusable="true" />

        <!-- 背景模式 -->
        <LinearLayout
            android:id="@+id/appBackgroundModeInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:layout_marginTop="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/appview_background_mode_title"
                android:textColor="@color/appview_text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light"
                android:paddingStart="4dp"
                android:paddingBottom="4dp" />

            <RadioGroup
                android:id="@+id/appBackgroundModeGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                android:layout_gravity="start">

                <RadioButton
                    android:id="@+id/appBackgroundModeArtwork"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="32dp"
                    android:text="@string/appview_background_mode_artwork"
                    android:textColor="@color/appview_text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:buttonTint="@color/appview_text_primary"
                    android:paddingEnd="@dimen/appview_edge_margin" />

                <RadioButton
                    android:id="@+id/appBackgroundModeSoftColor"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="32dp"
                    android:text="@string/appview_background_mode_soft_color"
                    android:textColor="@color/appview_text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:buttonTint="@color/appview_text_primary"
                    android:paddingEnd="@dimen/appview_edge_margin" />

            </RadioGroup>
        </LinearLayout>

        <!-- 屏幕组合模式区域 -->
        <LinearLayout
            android:id="@+id/screenCombinationModeInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:layout_marginTop="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_screen_combination_mode"
                android:textColor="@color/appview_text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif-light"
                android:paddingStart="4dp"
                android:paddingEnd="@dimen/appview_edge_margin"
                android:paddingBottom="4dp" />

            <TextView
                android:id="@+id/screenCombinationModeLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/appview_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:maxLines="2"
                android:ellipsize="end"
                android:paddingTop="4dp"
                android:paddingBottom="2dp"
                android:paddingStart="4dp"
                android:paddingEnd="@dimen/appview_edge_margin"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- 显示器选择区域 -->
        <LinearLayout
            android:id="@+id/displaySelectionInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="start"
            android:layout_marginTop="4dp"
            android:visibility="gone">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/appview_display_selection_title"
                    android:textColor="@color/appview_text_secondary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-light"
                    android:paddingStart="4dp"
                    android:paddingEnd="12dp" />

                <TextView
                    android:id="@+id/clearDisplaySelectionButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="56dp"
                    android:minHeight="32dp"
                    android:text="@string/appview_display_selection_clear"
                    android:textColor="@color/appview_text_primary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-light"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:background="@drawable/appview_frosted_action_background"
                    android:elevation="2dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <RadioGroup
                android:id="@+id/displayRadioGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start"
                android:layout_gravity="start" />

        </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- 标题区域（电脑名 + 应用名 + 恢复箭头） -->
    <TextView
        android:id="@+id/appListText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/topPanelToggle"
        android:layout_marginTop="4dp"
        android:layout_marginStart="@dimen/appview_content_margin"
        android:layout_marginEnd="@dimen/appview_content_margin"
        android:gravity="end"
        android:paddingBottom="@dimen/appview_content_padding"
        android:preferKeepClear="true"
        android:textSize="24sp"
        android:autoSizeTextType="uniform"
        android:autoSizeMinTextSize="14sp"
        android:autoSizeMaxTextSize="28sp"
        android:autoSizeStepGranularity="1sp"
        android:textStyle="normal"
        android:fontFamily="sans-serif-light"
        android:textColor="@color/appview_text_primary"
        android:shadowColor="@color/appview_text_shadow"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="4"
        android:maxLines="3"
        android:ellipsize="end"
        android:lineSpacingExtra="4dp"
        android:breakStrategy="balanced"
        android:hyphenationFrequency="normal"
        android:clickable="true"
        android:focusable="true"
        android:background="?android:attr/selectableItemBackground" />

    <!-- 底部信息容器 -->
    <LinearLayout
        android:id="@+id/bottomInfoContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginStart="@dimen/appview_content_margin"
        android:layout_marginEnd="@dimen/appview_content_margin"
        android:layout_marginBottom="@dimen/appview_bottom_margin"
        android:orientation="vertical"
        android:gravity="end">

        <!-- 上一次设置信息 -->
        <LinearLayout
            android:id="@+id/lastSettingsInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:visibility="gone">

            <CheckBox
                android:id="@+id/useLastSettingsCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:focusable="true"
                android:text="@string/app_last_settings_use_checkbox"
                android:textColor="@color/appview_text_secondary"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:buttonTint="@color/appview_text_primary"
                android:checked="false" />

            <TextView
                android:id="@+id/lastSettingsText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textColor="@color/appview_text_secondary"
                android:shadowColor="@color/appview_text_shadow"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2"
                android:fontFamily="sans-serif-light"
                android:background="@drawable/settings_info_background"
                android:padding="@dimen/appview_edge_margin"
                android:maxLines="3"
                android:ellipsize="end"
                android:lineSpacingExtra="2dp"
                android:text="@string/app_last_settings_title" />

        </LinearLayout>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/screenCombinationModeOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/screen_combination_mode_picker_background"
        android:clickable="true"
        android:focusable="true"
        android:elevation="24dp"
        android:visibility="gone" />

</RelativeLayout>
